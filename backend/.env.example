# Port configuration
PORT=3000
NODE_ENV=development

# External API base URLs
RDAP_BASE_URL=https://rdap.org/domain
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/search

# User Agent header for external HTTP calls (Required by OSM Nominatim)
USER_AGENT=CompanyLookupAgent/1.0 (admin@example.com)
